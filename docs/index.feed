k \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"kr\"\u003eexport\u003c/span\u003e \u003cspan class=\"kr\"\u003econst\u003c/span\u003e \u003cspan class=\"nx\"\u003eappConfig\u003c/span\u003e: \u003cspan class=\"kt\"\u003eApplicationConfig\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"nx\"\u003eproviders\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e[\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eprovideZonelessChangeDetection\u003c/span\u003e\u003cspan class=\"p\"\u003e(),\u003c/span\u003e \u003cspan class=\"c1\"\u003e// Phase 1\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"nx\"\u003eprovideRouter\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"nx\"\u003eroutes\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"nx\"\u003ewithComponentInputBinding\u003c/span\u003e\u003cspan class=\"p\"\u003e(),\u003c/span\u003e \u003cspan class=\"c1\"\u003e// Phase 3A — NEW\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e      \u003cspan class=\"nx\"\u003ewithViewTransitions\u003c/span\u003e\u003cspan class=\"p\"\u003e(),\u003c/span\u003e \u003cspan class=\"c1\"\u003e// Phase 3A — NEW\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eprovideClientHydration\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"nx\"\u003ewithIncrementalHydration\u003c/span\u003e\u003cspan class=\"p\"\u003e(),\u003c/span\u003e \u003cspan class=\"c1\"\u003e// Phase 3A — UPGRADED\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eprovideHttpClient\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003ewithInterceptors\u003c/span\u003e\u003cspan class=\"p\"\u003e([\u003c/span\u003e\u003cspan class=\"nx\"\u003eauthInterceptor\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e \u003cspan class=\"nx\"\u003eloggingInterceptor\u003c/span\u003e\u003cspan class=\"p\"\u003e])),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"c1\"\u003e// ...DI providers (Phase 1)\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"p\"\u003e{\u003c/span\u003e \u003cspan class=\"nx\"\u003eprovide\u003c/span\u003e: \u003cspan class=\"kt\"\u003eErrorHandler\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e \u003cspan class=\"nx\"\u003euseClass\u003c/span\u003e: \u003cspan class=\"kt\"\u003eGlobalErrorHandler\u003c/span\u003e \u003cspan class=\"p\"\u003e},\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e],\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e};\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003chr\u003e\n\u003ch2 id=\"-the-teaching-moment-configuration-as-documentation\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-the-teaching-moment-configuration-as-documentation\" class=\"header-mark\"\u003e\u003c/a\u003e4 🎓 The Teaching Moment: Configuration as Documentation\u003c/h2\u003e\u003cp\u003eNotice how our \u003ccode\u003eapp.config.ts\u003c/code\u003e tells a story. Each provider, each \u003ccode\u003ewith*()\u003c/code\u003e function, is a deliberate architectural decision. By reading this single file, a new developer on the team can understand:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eWe don\u0026rsquo;t use Zone.js.\u003c/li\u003e\n\u003cli\u003eOur routes bind data directly to component inputs.\u003c/li\u003e\n\u003cli\u003eOur navigation transitions are animated.\u003c/li\u003e\n\u003cli\u003eOur SSR uses incremental hydration.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eThis is \u003cstrong\u003eConfiguration as Documentation\u003c/strong\u003e — and it\u0026rsquo;s one of the hallmarks of enterprise-grade Angular.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"-phase-3a-complete\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-phase-3a-complete\" class=\"header-mark\"\u003e\u003c/a\u003e5 🏁 Phase 3A Complete!\u003c/h2\u003e\u003cp\u003eLet\u0026rsquo;s recap what we accomplished:\u003c/p\u003e\n\u003ctable\u003e\n  \u003cthead\u003e\n      \u003ctr\u003e\n          \u003cth\u003ePost\u003c/th\u003e\n          \u003cth\u003eFeature\u003c/th\u003e\n          \u003cth\u003eImpact\u003c/th\u003e\n      \u003c/tr\u003e\n  \u003c/thead\u003e\n  \u003ctbody\u003e\n      \u003ctr\u003e\n          \u003ctd\u003e\u003ca href=\"/2026-03-18-phase-03a-part-01\" rel=\"\"\u003ePart 1\u003c/a\u003e\u003c/td\u003e\n          \u003ctd\u003eFunctional Resolvers\u003c/td\u003e\n          \u003ctd\u003eData is ready before the route renders\u003c/td\u003e\n      \u003c/tr\u003e\n      \u003ctr\u003e\n          \u003ctd\u003e\u003ca href=\"/2026-03-18-phase-03a-part-02\" rel=\"\"\u003ePart 2\u003c/a\u003e\u003c/td\u003e\n          \u003ctd\u003eSignal Input Binding\u003c/td\u003e\n          \u003ctd\u003eZero-boilerplate route data consumption\u003c/td\u003e\n      \u003c/tr\u003e\n      \u003ctr\u003e\n          \u003ctd\u003ePart 3 (this post)\u003c/td\u003e\n          \u003ctd\u003eView Transitions + Hydration\u003c/td\u003e\n          \u003ctd\u003eCinematic UX and SSR performance\u003c/td\u003e\n      \u003c/tr\u003e\n  \u003c/tbody\u003e\n\u003c/table\u003e\n\u003cp\u003e\u003cstrong\u003eNext up:\u003c/strong\u003e Phase 3B, where we deep-dive into Angular\u0026rsquo;s \u003ccode\u003eresource()\u003c/code\u003e API for reactive, cancelable data fetching.\u003c/p\u003e\n\u003chr\u003e\n\u003cp\u003e\u003cem\u003eCurious about how these features interact? The beauty is in the \u003ccode\u003eapp.config.ts\u003c/code\u003e — one file, three lines, three massive UX improvements. Check it out on GitHub!\u003c/em\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "Angular Enterprise Dashboard - Phase 3A.2: From Route to Component — Signal Inputs \u0026 the KPI Dashboard",
        "date_published" : "2026-02-18T14:05:00+02:00",
        "date_modified" : "2026-03-01T09:45:42+02:00",
        "id" : "https://buffos.github.io/2026-03-18-phase-03a-part-02/",
        "url" : "https://buffos.github.io/2026-03-18-phase-03a-part-02/",
        "summary": "In the previous post, our resolver pre-fetched the dashboard data and handed it to the Router. But how does the component actually receive it?\n",
        "content_html" : "\u003cp\u003eIn the \u003ca href=\"/blog/phase-03a-part-01\" rel=\"\"\u003eprevious post\u003c/a\u003e, our resolver pre-fetched the dashboard data and handed it to the Router. But how does the \u003cem\u003ecomponent\u003c/em\u003e actually receive it?\u003c/p\u003e\n\u003ch1 id=\"zero-boilerplate-data-binding\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#zero-boilerplate-data-binding\" class=\"header-mark\"\u003e\u003c/a\u003eZero-Boilerplate Data Binding\u003c/h1\u003e\u003cp\u003eTraditionally, you\u0026rsquo;d inject \u003ccode\u003eActivatedRoute\u003c/code\u003e, subscribe to \u003ccode\u003edata\u003c/code\u003e, and manually assign values. That\u0026rsquo;s a lot of ceremony for something that should be simple.\u003c/p\u003e\n\u003cp\u003eIn this post, we\u0026rsquo;ll see how \u003cstrong\u003e\u003ccode\u003ewithComponentInputBinding()\u003c/code\u003e\u003c/strong\u003e and \u003cstrong\u003esignal \u003ccode\u003einput()\u003c/code\u003e\u003c/strong\u003e create a seamless, zero-boilerplate bridge between route data and component state.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"-the-enabler-withcomponentinputbinding\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-the-enabler-withcomponentinputbinding\" class=\"header-mark\"\u003e\u003c/a\u003e1 🔑 The Enabler: \u003ccode\u003ewithComponentInputBinding()\u003c/code\u003e\u003c/h2\u003e\u003cp\u003eThis is a one-time configuration in \u003ccode\u003eapp.config.ts\u003c/code\u003e:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003etypescript\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9