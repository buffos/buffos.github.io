26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\r\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\r\n      \u003c/button\u003e\r\n        \r\n      \u003cbutton \r\n        class=\"\r\n          tw-select-none \r\n          tw-mx-2 \r\n          tw-block \r\n          group-[.is-open]:tw-hidden \r\n          print:!tw-hidden\" \r\n        disabled\r\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \r\n    id=\"codeblock-id-37\" \r\n    class=\"\r\n      chroma \r\n      !tw-block \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e% With content:\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e\u003cspan class=\"k\"\u003e\\NewDocumentCommand\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\digitbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e}{\u003c/span\u003eO\u003cspan class=\"nb\"\u003e{\u003c/span\u003e8mm\u003cspan class=\"nb\"\u003e}\u003c/span\u003e O\u003cspan class=\"nb\"\u003e{\u003c/span\u003e10mm\u003cspan class=\"nb\"\u003e}\u003c/span\u003e m\u003cspan class=\"nb\"\u003e}{\u003c/span\u003e\u003cspan class=\"c\"\u003e%\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e  \u003cspan class=\"k\"\u003e\\begingroup\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"k\"\u003e\\setlength\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\fboxsep\u003c/span\u003e\u003cspan class=\"nb\"\u003e}{\u003c/span\u003e0pt\u003cspan class=\"nb\"\u003e}\u003c/span\u003e\u003cspan class=\"c\"\u003e%\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e  \u003cspan class=\"k\"\u003e\\fbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\makebox\u003c/span\u003e\u003cspan class=\"na\"\u003e[#1][c]\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\rule\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e0pt\u003cspan class=\"nb\"\u003e}{\u003c/span\u003e#2\u003cspan class=\"nb\"\u003e}\u003c/span\u003e\u003cspan class=\"k\"\u003e\\smash\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e#3\u003cspan class=\"nb\"\u003e}}}\u003c/span\u003e\u003cspan class=\"c\"\u003e%\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e  \u003cspan class=\"k\"\u003e\\endgroup\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e% Blank box:\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e\u003cspan class=\"k\"\u003e\\NewDocumentCommand\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\emptybox\u003c/span\u003e\u003cspan class=\"nb\"\u003e}{\u003c/span\u003eO\u003cspan class=\"nb\"\u003e{\u003c/span\u003e8mm\u003cspan class=\"nb\"\u003e}\u003c/span\u003e O\u003cspan class=\"nb\"\u003e{\u003c/span\u003e10mm\u003cspan class=\"nb\"\u003e}}{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\digitbox\u003c/span\u003e\u003cspan class=\"na\"\u003e[#1][#2]\u003c/span\u003e\u003cspan class=\"nb\"\u003e{}}\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003cp\u003eWe create an \u003ccode\u003eemptybox\u003c/code\u003e command, to be able to have easy access to empty squares.\u003c/p\u003e\n\u003ch3 id=\"2-what-does-that-smash-does\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#2-what-does-that-smash-does\" class=\"header-mark\"\u003e\u003c/a\u003e16.2 2. What does that \u003ccode\u003e\\smash\u003c/code\u003e does?\u003c/h3\u003e\u003cp\u003e\u003ccode\u003e\\smash{stuff}\u003c/code\u003e tells TeX:\u003c/p\u003e\n\u003cblockquote\u003e\r\n  \u003cp\u003e\u0026ldquo;Ignore the height and depth of \u003cem\u003estuff\u003c/em\u003e when calculating vertical spacing. Treat it as if it has zero height and depth.\u0026rdquo;\u003c/p\u003e\r\n\u003c/blockquote\u003e\u003cul\u003e\n\u003cli\u003e\u003cstrong\u003eHorizontal width is kept.\u003c/strong\u003e\u003c/li\u003e\n\u003cli\u003e\u003cstrong\u003eVertical dimensions are suppressed.\u003c/strong\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch3 id=\"3-why-it-matters-here\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#3-why-it-matters-here\" class=\"header-mark\"\u003e\u003c/a\u003e16.3 3. Why it matters here?\u003c/h3\u003e\u003cp\u003eIf you just put \u003ccode\u003e#3\u003c/code\u003e inside, the box’s vertical size would be influenced by how tall that character or number is (e.g. an uppercase \u003ccode\u003eA\u003c/code\u003e vs. lowercase \u003ccode\u003eg\u003c/code\u003e vs. digit \u003ccode\u003e5\u003c/code\u003e). That means the boxes could end up with \u003cem\u003eslightly different heights\u003c/em\u003e depending on their content.\u003c/p\u003e\n\u003cp\u003eBy using \u003ccode\u003e\\smash{#3}\u003c/code\u003e:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eThe height/depth of \u003ccode\u003e#3\u003c/code\u003e is ignored.\u003c/li\u003e\n\u003cli\u003eThe \u003cstrong\u003erule\u003c/strong\u003e (\u003ccode\u003e\\rule{0pt}{#2}\u003c/code\u003e) alone controls the vertical dimension.\u003c/li\u003e\n\u003cli\u003eThus, \u003cstrong\u003eall boxes stay the same height\u003c/strong\u003e, and the content is vertically centered inside them.\u003c/li\u003e\n\u003c/ul\u003e\n\u003cp\u003eNotes:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e\u003ccode\u003e\\raisebox{0pt}[0pt][0pt]{#3}\u003c/code\u003e is equivalent to \u003ccode\u003e\\smash{$3}\u003c/code\u003e\u003c/li\u003e\n\u003cli\u003eInstead of \u003ccode\u003e\\rule{0pt}{#2}\u003c/code\u003e, we can use a \u0026ldquo;phantom character\u0026rdquo; that fixes height: \u003ccode\u003e\\fbox{\\makebox[#1][c]{\\vphantom{\\rule{0pt}{#2}}#3}}\u003c/code\u003e\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"our-digits-are-too-small-and-not-vertically-aligned\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#our-digits-are-too-small-and-not-vertically-aligned\" class=\"header-mark\"\u003e\u003c/a\u003e17 Our digits are too small and not vertically aligned.\u003c/h2\u003e\u003cp\u003eWhat we see is that our digits are too small compared to the box. We would like them to grow with the box.\nLet\u0026rsquo;s fix it.\u003c/p\u003e\n\u003ch3 id=\"1-changing-the-command\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#1-changing-the-command\" class=\"header-mark\"\u003e\u003c/a\u003e17.1 1. Changing the command\u003c/h3\u003e\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003eLatex\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16zm0 320H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-1