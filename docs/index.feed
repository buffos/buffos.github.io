.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \r\n    id=\"codeblock-id-36\" \r\n    class=\"\r\n      chroma \r\n      !tw-block \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003e\\fbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\makebox\u003c/span\u003e\u003cspan class=\"na\"\u003e[#1]\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\rule\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e0pt\u003cspan class=\"nb\"\u003e}{\u003c/span\u003e#2\u003cspan class=\"nb\"\u003e}}}\u003c/span\u003e ␣ \u003cspan class=\"k\"\u003e\\endgroup\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003cp\u003eThat extra space can:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003eSneak into your boxes as an actual space of width ~0.3em.\u003c/li\u003e\n\u003cli\u003eShift alignment slightly.\u003c/li\u003e\n\u003cli\u003eMake the page look different, depending on where the macro is used.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch5 id=\"rule-of-thumb\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#rule-of-thumb\" class=\"header-mark\"\u003e\u003c/a\u003e15.4.0.3 \u003cstrong\u003eRule of thumb\u003c/strong\u003e\u003c/h5\u003e\u003cul\u003e\n\u003cli\u003eIf you’re writing macros and don’t want spurious spaces creeping in, end lines with \u003ccode\u003e%\u003c/code\u003e.\u003c/li\u003e\n\u003cli\u003eIf spaces/newlines are \u003cem\u003esignificant\u003c/em\u003e, don’t use \u003ccode\u003e%\u003c/code\u003e.\u003c/li\u003e\n\u003c/ul\u003e\n\u003ch2 id=\"we-want-our-digit-boxes-to-have-contents\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#we-want-our-digit-boxes-to-have-contents\" class=\"header-mark\"\u003e\u003c/a\u003e16 We want our digit boxes to have contents.\u003c/h2\u003e\u003ch3 id=\"1-changing-our-code\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#1-changing-our-code\" class=\"header-mark\"\u003e\u003c/a\u003e16.1 1. Changing our code.\u003c/h3\u003e\u003cp\u003eLet\u0026rsquo;s change our command to\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003eLatex\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.07-14.19v-3.31C84.34 356 80.5 352 73 352H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8h22.83a157.41 157.41 0 0 0-11 12.31l-5.61 7c-4 5.07-5.25 10.13-2.8 14.88l1.05 1.93c3 5.76 6.29 7.88 12.25 7.88h4.73c10.33 0 15.94 2.44 15.94 9.09 0 4.72-4.2 8.22-14.36 8.22a41.54 41.54 0 0 1-15.47-3.12c-6.49-3.88-11.74-3.5-15.6 3.12l-5.59 9.31c-3.72 6.13-3.19 11.72 2.63 15.94 7.71 4.69 20.38 9.44 37 9.44 34.16 0 48.5-22.75 48.5-44.12-.03-14.38-9.12-29.76-28.73-34.88zM496 224H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zm0-160H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16V80a16 16 0 0 0-16-16zm0 320H176a16 16 0 0 0-16 16v32a16 16 0 0 0 16 16h320a16 16 0 0 0 16-16v-32a16 16 0 0 0-16-16zM16 160h64a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H64V40a8 8 0 0 0-8-8H32a8 8 0 0 0-7.14 4.42l-8 16A8 8 0 0 0 24 64h8v64H16a8 8 0 0 0-8 8v16a8 8 0 0 0 8 8zm-3.91 160H80a8 8 0 0 0 8-8v-16a8 8 0 0 0-8-8H41.32c3.29-10.29 48.34-18.68 48.34-56.44 0-29.06-25-39.56-44.47-39.56-21.36 0-33.8 10-40.46 18.75-4.37 5.59-3 10.84 2.8 15.37l8.58 6.88c5.61 4.56 11 2.47 16.12-2.44a13.44 13.44 0 0 1 9.46-3.84c3.33 0 9.28 1.56 9.28 8.75C51 248.19 0 257.31 0 304.59v4C0 316 5.08 320 12.09 3