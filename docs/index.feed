on\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 448 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M433.941 65.941l-51.882-51.882A48 48 0 0 0 348.118 0H176c-26.51 0-48 21.49-48 48v48H48c-26.51 0-48 21.49-48 48v320c0 26.51 21.49 48 48 48h224c26.51 0 48-21.49 48-48v-48h80c26.51 0 48-21.49 48-48V99.882a48 48 0 0 0-14.059-33.941zM266 464H54a6 6 0 0 1-6-6V150a6 6 0 0 1 6-6h74v224c0 26.51 21.49 48 48 48h96v42a6 6 0 0 1-6 6zm128-96H182a6 6 0 0 1-6-6V54a6 6 0 0 1 6-6h106v88c0 13.255 10.745 24 24 24h88v202a6 6 0 0 1-6 6zm6-256h-64V48h9.632c1.591 0 3.117.632 4.243 1.757l48.368 48.368a6 6 0 0 1 1.757 4.243V112z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\r\n          \u003cspan class=\"check-icon tw-hidden\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\r\n      \u003c/button\u003e\r\n        \r\n      \u003cbutton \r\n        class=\"\r\n          tw-select-none \r\n          tw-mx-2 \r\n          tw-block \r\n          group-[.is-open]:tw-hidden \r\n          print:!tw-hidden\" \r\n        disabled\r\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \r\n    id=\"codeblock-id-12\" \r\n    class=\"\r\n      chroma \r\n      !tw-block \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e// The OLD way — fragile, manual, and error-prone\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e\u003cspan class=\"nx\"\u003engOnInit() {\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"k\"\u003ethis\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003esearchQuery$\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003epipe\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003edebounceTime\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"mi\"\u003e300\u003c/span\u003e\u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eswitchMap\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003eq\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=\"k\"\u003ethis\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eapi\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003esearch\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003eq\u003c/span\u003e\u003cspan class=\"p\"\u003e)),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003etakeUntilDestroyed\u003c/span\u003e\u003cspan class=\"p\"\u003e(),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e).\u003c/span\u003e\u003cspan class=\"nx\"\u003esubscribe\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"nx\"\u003edata\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=\"k\"\u003ethis\u003c/span\u003e\u003cspan class=\"p\"\u003e.\u003c/span\u003e\u003cspan class=\"nx\"\u003eprojects\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"nx\"\u003edata\u003c/span\u003e\u003cspan class=\"p\"\u003e);\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e}\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003cp\u003eWith \u003ccode\u003eresource()\u003c/code\u003e, you get:\u003c/p\u003e\n\u003cul\u003e\n\u003cli\u003e✅ Automatic cancellation (no \u003ccode\u003eswitchMap\u003c/code\u003e needed)\u003c/li\u003e\n\u003cli\u003e✅ Status tracking (no manual \u003ccode\u003eisLoading\u003c/code\u003e boolean)\u003c/li\u003e\n\u003cli\u003e✅ Signal-native (no \u003ccode\u003e.subscribe()\u003c/code\u003e, no memory leak risk)\u003c/li\u003e\n\u003cli\u003e✅ Typed params and value\u003c/li\u003e\n\u003c/ul\u003e\n\u003chr\u003e\n\u003ch2 id=\"coming-up-next\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#coming-up-next\" class=\"header-mark\"\u003e\u003c/a\u003e6 Coming Up Next\u003c/h2\u003e\u003cp\u003eWe\u0026rsquo;ve declared the resource, but we haven\u0026rsquo;t talked about what happens when the user types \u003cem\u003efast\u003c/em\u003e. In \u003cstrong\u003ePhase 3B.2\u003c/strong\u003e, we\u0026rsquo;ll dive into the \u003cstrong\u003eabort and cancellation\u003c/strong\u003e patterns that make search-as-you-type smooth and efficient.\u003c/p\u003e\n\u003chr\u003e\n\u003cp\u003e\u003cem\u003eThis is the beginning of a deep dive. The full \u003ccode\u003eProjectsComponent\u003c/code\u003e is a 300+ line showcase of \u003ccode\u003eresource()\u003c/code\u003e. Explore it on GitHub!\u003c/em\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "Angular Enterprise Dashboard - Phase 3A.3: Polishing the Experience — View Transitions \u0026 Incremental Hydration",
        "date_published" : "2026-02-18T14:10:00+02:00",
        "date_modified" : "2026-03-01T10:53:36+02:00",
        "id" : "https://buffos.github.io/2026-03-18-phase-03a-part-03/",
        "url" : "https://buffos.github.io/2026-03-18-phase-03a-part-03/",
        "summary": "We\u0026rsquo;ve built the data pipeline (Part 1) and the dashboard UI (Part 2). The app works. But \u0026ldquo;works\u0026rdquo; and \u0026ldquo;feels amazing\u0026rdquo; are two very different things.\n",
        "content_html" : "\u003cp\u003eWe\u0026rsquo;ve built the data pipeline (\u003ca href=\"/blog/2026-03-18-phase-03a-part-01\" rel=\"\"\u003ePart 1\u003c/a\u003e) and the dashboard UI (\u003ca href=\"/2026-03-18-phase-03a-part-02\" rel=\"\"\u003ePart 2\u003c/a\u003e). The app works. But \u0026ldquo;works\u0026rdquo; and \u0026ldquo;feels amazing\u0026rdquo; are two very different things.\u003c/p\u003e\n\u003ch1 id=\"the-invisible-upgrades-that-make-everything-feel-premium\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#the-invisible-upgrades-that-make-everything-feel-premium\" class=\"header-mark\"\u003e\u003c/a\u003eThe Invisible Upgrades That Make Everything Feel Premium\u003c/h1\u003e\u003cp\u003eIn this final Phase 3A post, we tackle two framework-level optimizations that elevate our application from functional to \u003cem\u003epolished\u003c/em\u003e: \u003cstrong\u003eView Transitions\u003c/strong\u003e and \u003cstrong\u003eIncremental Hydration\u003c/strong\u003e.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"-view-transitions-cinematic-route-changes\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-view-transitions-cinematic-route-changes\" class=\"header-mark\"\u003e\u003c/a\u003e1 ✨ View Transitions: Cinematic Route Changes\u003c/h2\u003e\u003ch3 id=\"the-problem\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#the-problem\" class=\"header-mark\"\u003e\u003c/a\u003e1.1 The Problem\u003c/h3\u003e\u003cp\u003eBy default, when a user navigates between routes, the old view instantly disappears and the new view instantly appears. It\u0026rsquo;s functional, but it feels abrupt — like flipping a light switch.\u003c/p\u003e\n\u003ch3 id=\"the-solution\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#the-solution\" class=\"header-mark\"\u003e\u003c/a\u003e1.2 The Solution\u003c/h3\u003e\u003cp\u003eThe \u003cstrong\u003eView Transitions API\u003c/strong\u003e is a browser-native feature that Angular can hook into. It creates a smooth, animated crossfade between the outgoing and incoming route.\u003c/p\u003e\n\u003cp\u003eEnabling it is a single line:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003etypescript\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fonta