tton\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \r\n    id=\"codeblock-id-45\" \r\n    class=\"\r\n      chroma \r\n      !tw-block \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003e\\noalign\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\vskip\u003c/span\u003e 6pt\u003cspan class=\"nb\"\u003e}\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003cp\u003eThis forces vertical space between specific rows (and around \u003ccode\u003e\\cline\u003c/code\u003e), this is the “nuclear option” that always works inside array/tabular.\u003c/p\u003e\n\u003cp\u003eThe rest do not require any explanation.\u003c/p\u003e",
