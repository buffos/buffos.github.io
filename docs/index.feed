u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"o\"\u003e+\u003c/span\u003e\u003cspan class=\"nb\"\u003e} \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\emptybox\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\emptybox\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\emptybox\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\\\\u003c/span\u003e\u003cspan class=\"nb\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"c\"\u003e% --- Explicit extra space between rows (very reliable) ---\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\noalign\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\vskip\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"m\"\u003e6\u003c/span\u003e\u003cspan class=\"nb\"\u003ept}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"o\"\u003e+\u003c/span\u003e\u003cspan class=\"nb\"\u003e           \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\digitbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\Large\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"m\"\u003e3\u003c/span\u003e\u003cspan class=\"nb\"\u003e} \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\digitbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\Large\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"m\"\u003e7\u003c/span\u003e\u003cspan class=\"nb\"\u003e} \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\digitbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\Large\u003c/span\u003e\u003cspan class=\"nb\"\u003e A} \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\\\\u003c/span\u003e\u003cspan class=\"nb\"\u003e\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"c\"\u003e% Space above/below the rule so it doesn\u0026#39;t touch the boxes\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c\"\u003e\u003c/span\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\noalign\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\vskip\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"m\"\u003e4\u003c/span\u003e\u003cspan class=\"nb\"\u003ept}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\cline\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"m\"\u003e2\u003c/span\u003e\u003cspan class=\"o\"\u003e-\u003c/span\u003e\u003cspan class=\"m\"\u003e4\u003c/span\u003e\u003cspan class=\"nb\"\u003e}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e  \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\noalign\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\vskip\u003c/span\u003e\u003cspan class=\"nb\"\u003e \u003c/span\u003e\u003cspan class=\"m\"\u003e6\u003c/span\u003e\u003cspan class=\"nb\"\u003ept}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e              \u0026amp;                     \u0026amp;                     \u0026amp; \u003c/span\u003e\u003cspan class=\"nv\"\u003e\\makebox\u003c/span\u003e\u003cspan class=\"o\"\u003e[\u003c/span\u003e\u003cspan class=\"m\"\u003e10\u003c/span\u003e\u003cspan class=\"nb\"\u003emm\u003c/span\u003e\u003cspan class=\"o\"\u003e][\u003c/span\u003e\u003cspan class=\"nb\"\u003er\u003c/span\u003e\u003cspan class=\"o\"\u003e]\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"m\"\u003e123\u003c/span\u003e\u003cspan class=\"nb\"\u003e}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e\u003c/span\u003e\u003cspan class=\"nv\"\u003e\\end\u003c/span\u003e\u003cspan class=\"nb\"\u003e{array}\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"nb\"\u003e\u003c/span\u003e\u003cspan class=\"s\"\u003e\\]\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003ch3 id=\"start-math-mode\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#start-math-mode\" class=\"header-mark\"\u003e\u003c/a\u003e18.1 Start math mode\u003c/h3\u003e\u003cp\u003eWe start with \u003ccode\u003e\\[ \\]\u003c/code\u003e which is equivalent to \u003ccode\u003e\\begin{displaymath}\u003c/code\u003e\u003c/p\u003e\n\u003ch3 id=\"start-defining-an-array-layout\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#start-defining-an-array-layout\" class=\"header-mark\"\u003e\u003c/a\u003e18.2 Start defining an array layout\u003c/h3\u003e\u003cp\u003ethen we do\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003elatex\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M61.77 401l17.5-20.15a19.92 19.92 0 0 0 5.