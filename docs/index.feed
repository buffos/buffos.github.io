r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003e\\fbox\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\makebox\u003c/span\u003e\u003cspan class=\"na\"\u003e[#1]\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e\u003cspan class=\"k\"\u003e\\rule\u003c/span\u003e\u003cspan class=\"nb\"\u003e{\u003c/span\u003e0pt\u003cspan class=\"nb\"\u003e}{\u003c/span\u003e#2\u003cspan class=\"nb\"\u003e}}}\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"k\"\u003e\\endgroup\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003cp\u003eHere, after the \u003ccode\u003e}\u003c/code\u003e you have an implicit space (because of the line break). LaTeX sees it as if you had typed:\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/