1.1, Code: MIT License) --\u003e\u003cpath d=\"M173.898 439.404l-166.4-166.4c-9.997-9.997-9.997-26.206 0-36.204l36.203-36.204c9.997-9.998 26.207-9.998 36.204 0L192 312.69 432.095 72.596c9.997-9.997 26.207-9.997 36.204 0l36.203 36.204c9.997 9.997 9.997 26.206 0 36.204l-294.4 294.401c-9.998 9.997-26.207 9.997-36.204-.001z\"/\u003e\u003c/svg\u003e\u003c/span\u003e\r\n      \u003c/button\u003e\r\n        \r\n      \u003cbutton \r\n        class=\"\r\n          tw-select-none \r\n          tw-mx-2 \r\n          tw-block \r\n          group-[.is-open]:tw-hidden \r\n          print:!tw-hidden\" \r\n        disabled\r\n        aria-hidden=\"true\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M328 256c0 39.8-32.2 72-72 72s-72-32.2-72-72 32.2-72 72-72 72 32.2 72 72zm104-72c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72zm-352 0c-39.8 0-72 32.2-72 72s32.2 72 72 72 72-32.2 72-72-32.2-72-72-72z\"/\u003e\u003c/svg\u003e\u003c/button\u003e\r\n    \u003c/div\u003e\r\n  \u003c/div\u003e\r\n  \u003cpre style=\"counter-reset: codeblock;\" class=\"tw-block tw-m-0 tw-p-0\"\u003e\u003ccode \r\n    id=\"codeblock-id-9\" \r\n    class=\"\r\n      chroma \r\n      !tw-block \r\n      tw-p-0\r\n      tw-m-0\r\n      tw-transition-[max-height] \r\n      tw-duration-500 \r\n      tw-ease-in-out \r\n      group-[.is-closed]:!tw-max-h-0 \r\n      group-[.is-wrap]:tw-text-wrap\r\n      tw-overflow-y-hidden\r\n      tw-overflow-x-auto\r\n      tw-scrollbar-thin\r\n      \"\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e// app.routes.ts\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e\u003cspan class=\"kr\"\u003eexport\u003c/span\u003e \u003cspan class=\"kr\"\u003econst\u003c/span\u003e \u003cspan class=\"nx\"\u003eroutes\u003c/span\u003e: \u003cspan class=\"kt\"\u003eRoutes\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u003c/span\u003e \u003cspan class=\"p\"\u003e[\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003epath\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;login\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003eloadComponent\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e()\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=\"kr\"\u003eimport\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;./features/auth/login.component\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ecanActivate\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003eguestGuard\u003c/span\u003e\u003cspan class=\"p\"\u003e],\u003c/span\u003e \u003cspan class=\"c1\"\u003e// Only for unauthenticated users\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e  \u003cspan class=\"p\"\u003e},\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003epath\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003ecanActivate\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e[\u003c/span\u003e\u003cspan class=\"nx\"\u003eauthGuard\u003c/span\u003e\u003cspan class=\"p\"\u003e],\u003c/span\u003e \u003cspan class=\"c1\"\u003e// The \u0026#34;Outer Wall\u0026#34;\n\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"c1\"\u003e\u003c/span\u003e    \u003cspan class=\"nx\"\u003eloadComponent\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e()\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=\"kr\"\u003eimport\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;./core/layout/app-shell.component\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"nx\"\u003echildren\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e[\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"p\"\u003e{\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e        \u003cspan class=\"nx\"\u003epath\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"s2\"\u003e\u0026#34;dashboard\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e,\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e        \u003cspan class=\"nx\"\u003eloadComponent\u003c/span\u003e\u003cspan class=\"o\"\u003e:\u003c/span\u003e \u003cspan class=\"p\"\u003e()\u003c/span\u003e \u003cspan class=\"o\"\u003e=\u0026gt;\u003c/span\u003e \u003cspan class=\"kr\"\u003eimport\u003c/span\u003e\u003cspan class=\"p\"\u003e(\u003c/span\u003e\u003cspan class=\"s2\"\u003e\u0026#34;./features/dashboard.component\u0026#34;\u003c/span\u003e\u003cspan class=\"p\"\u003e),\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e      \u003cspan class=\"p\"\u003e},\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e    \u003cspan class=\"p\"\u003e],\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e  \u003cspan class=\"p\"\u003e},\u003c/span\u003e\n\u003c/span\u003e\u003c/span\u003e\u003cspan class=\"line\"\u003e\u003cspan class=\"cl\"\u003e\u003cspan class=\"p\"\u003e];\u003c/span\u003e\u003c/span\u003e\u003c/span\u003e\u003c/code\u003e\u003c/pre\u003e\r\n\u003c/div\u003e\r\n\u003ch2 id=\"-the-teaching-moment-signals--guards\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-the-teaching-moment-signals--guards\" class=\"header-mark\"\u003e\u003c/a\u003e5 🎓 The Teaching Moment: Signals + Guards\u003c/h2\u003e\u003cp\u003eNotice how our guards use \u003ccode\u003eauthService.isAuthenticated()\u003c/code\u003e. Because this is a \u003cstrong\u003eComputed Signal\u003c/strong\u003e, it’s lightning-fast. The Router doesn\u0026rsquo;t need to wait for an Observable to emit; it gets the truth immediately.\u003c/p\u003e\n\u003ch2 id=\"coming-up-next\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#coming-up-next\" class=\"header-mark\"\u003e\u003c/a\u003e6 Coming Up Next\u003c/h2\u003e\u003cp\u003eWe\u0026rsquo;ve secured our routes, but where do our users actually \u0026ldquo;live\u0026rdquo;? In \u003cstrong\u003ePhase 2.3: Architecture of the Shell\u003c/strong\u003e, we\u0026rsquo;ll build the premium layout that hosts our dashboard features.\u003c/p\u003e\n\u003chr\u003e\n\u003cp\u003e\u003cem\u003eFound this useful? This dashboard is designed to showcase enterprise patterns. Check out the series history in the \u003ca href=\"https://github.com/your-username/angular-enterprise-dashboard/tree/main/docs/blog\" target=\"_blank\" rel=\"noopener noreferrer\"\u003edocs/blog\u003c/a\u003e directory!\u003c/em\u003e\u003c/p\u003e",
        "language": "en"
    },
    {
        "title" : "Angular Enterprise Dashboard - Phase 2.1: Reactive Authentication with Angular Signals",
        "date_published" : "2026-02-16T21:52:00+02:00",
        "date_modified" : "2026-02-16T22:47:53+02:00",
        "id" : "https://buffos.github.io/2026-03-16-phase-02-part-01/",
        "url" : "https://buffos.github.io/2026-03-16-phase-02-part-01/",
        "summary": "Welcome to Phase 2 of our Enterprise Dashboard journey. Now that we have our foundation (Phase 1), it\u0026rsquo;s time to build the \u0026ldquo;brain\u0026rdquo; of our application\u0026rsquo;s security: the Authentication Service.\n",
        "content_html" : "\u003cp\u003eWelcome to Phase 2 of our Enterprise Dashboard journey. Now that we have our foundation (\u003ca href=\"/blog/phase-01\" rel=\"\"\u003ePhase 1\u003c/a\u003e), it\u0026rsquo;s time to build the \u0026ldquo;brain\u0026rdquo; of our application\u0026rsquo;s security: the \u003cstrong\u003eAuthentication Service\u003c/strong\u003e.\u003c/p\u003e\n\u003ch1 id=\"elevating-state-authentication-in-the-signal-era\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#elevating-state-authentication-in-the-signal-era\" class=\"header-mark\"\u003e\u003c/a\u003eElevating State: Authentication in the Signal Era\u003c/h1\u003e\u003cp\u003eIn this post, we\u0026rsquo;ll explore how to manage complex authentication states using \u003cstrong\u003eAngular Signals\u003c/strong\u003e—without the overhead of heavy state management libraries.\u003c/p\u003e\n\u003chr\u003e\n\u003ch2 id=\"-the-philosophy-of-managed-state\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#-the-philosophy-of-managed-state\" class=\"header-mark\"\u003e\u003c/a\u003e1 🧠 The Philosophy of Managed State\u003c/h2\u003e\u003cp\u003eIn an enterprise app, Authentication isn\u0026rsquo;t just a boolean \u003ccode\u003eisLoggedIn\u003c/code\u003e. It\u0026rsquo;s a spectrum of states: \u003ccode\u003eLoading\u003c/code\u003e, \u003ccode\u003eAuthenticated\u003c/code\u003e, \u003ccode\u003eError\u003c/code\u003e, and \u003ccode\u003eGuest\u003c/code\u003e.\u003c/p\u003e\n\u003cp\u003eTraditionally, we might have used multiple \u003ccode\u003eBehaviorSubjects\u003c/code\u003e or a complex NgRx Store. With Signals, we can achieve the same predictability with much less boilerplate.\u003c/p\u003e\n\u003ch3 id=\"the-auth-state-model\" class=\"headerLink\"\u003e\r\n    \u003ca href=\"#the-auth-state-model\" class=\"header-mark\"\u003e\u003c/a\u003e1.1 The Auth State Model\u003c/h3\u003e\u003cp\u003eWe start by defining a single source of truth: our \u003ccode\u003eAuthState\u003c/code\u003e.\u003c/p\u003e\n\u003cdiv class=\"code-block highlight is-open show-line-numbers  tw-group tw-my-2\"\u003e\r\n  \u003cdiv class=\"\r\n    \r\n    tw-flex \r\n    tw-flex-row\r\n    tw-flex-1 \r\n    tw-justify-between \r\n    tw-w-full tw-bg-bgColor-secondary\r\n    \"\u003e      \r\n    \u003cbutton \r\n      class=\"\r\n        code-block-button\r\n        tw-mx-2 \r\n        tw-flex\r\n        tw-flex-row\r\n        tw-flex-1\"\r\n      aria-hidden=\"true\"\u003e\r\n          \u003cdiv class=\"group-[.is-open]:tw-rotate-90 tw-transition-[transform] tw-duration-500 tw-ease-in-out print:!tw-hidden tw-w-min tw-h-min tw-my-1 tw-mx-1\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 320 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MIT License) --\u003e\u003cpath d=\"M285.476 272.971L91.132 467.314c-9.373 9.373-24.569 9.373-33.941 0l-22.667-22.667c-9.357-9.357-9.375-24.522-.04-33.901L188.505 256 34.484 101.255c-9.335-9.379-9.317-24.544.04-33.901l22.667-22.667c9.373-9.373 24.569-9.373 33.941 0L285.475 239.03c9.373 9.372 9.373 24.568.001 33.941z\"/\u003e\u003c/svg\u003e\u003c/div\u003e\r\n          \u003cp class=\"tw-select-none !tw-my-1\"\u003etypescript\u003c/p\u003e\r\n      \u003c/button\u003e\r\n\r\n   \u003cdiv class=\"tw-flex\"\u003e\r\n      \u003cbutton \r\n        class=\"\r\n          line-number-button\r\n          tw-mx-2 \r\n          tw-hidden \r\n          group-[.is-open]:tw-block \r\n          group-[.show-line-numbers]:tw-text-fgColor-link \r\n          print:!tw-hidden\" \r\n        title=\"Toggle line numbers\"\u003e\u003csvg class=\"icon\"\n    xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 512 512\"\u003e\u003c!-- Font Awesome Free 5.15.4 by @fontawesome - https://fontawesome.com License - https://fontawesome.com/license/free (Icons: CC BY 4.0, Fonts: SIL OFL 1.1, Code: MI